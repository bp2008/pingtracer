<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<RootNamespace>PingTracer</RootNamespace>
		<AssemblyName>PingTracer</AssemblyName>
		<UseWindowsForms>true</UseWindowsForms>
		<ApplicationIcon>pingtracer.ico</ApplicationIcon>
		<Version>2.1.0.0</Version>
		<Copyright>Copyright Brian Pearce 2026</Copyright>
		<Product>PingTracer</Product>
		<ApplicationHighDpiMode>SystemAware</ApplicationHighDpiMode>
		<ForceDesignerDpiUnaware>true</ForceDesignerDpiUnaware>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.0-preview.*" />
	</ItemGroup>

</Project>